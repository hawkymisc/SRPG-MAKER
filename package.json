{
  "name": "srpg-maker",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "test:golden": "tsx e2e/golden/harness.mts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "dev:runtime": "pnpm --filter @srpg/runtime dev",
    "baseline:m2": "tsx scripts/m2-baseline.mts"
  },
  "dependencies": {
    "@srpg/shared": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
